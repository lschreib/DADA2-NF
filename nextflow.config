/*
 * Root Nextflow configuration for DADA2-NF
 * nf-core migration scaffold
 */

manifest {
    name            = "DADA2-NF: Nextflow-powered DADA2 implementation"
    author          = 'Lars Schreiber'
    description     = 'Amplicon sequencing pipeline for DADA2-based processing.'
    homePage        = 'https://github.com/lschreib/DADA2-NF'
    version         = '0.2.0'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.10.0'
}

includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'
includeConfig 'conf/resources.config'

profiles {
    test {
        includeConfig 'conf/test.config'
    }

    singularity {
        includeConfig 'conf/singularity.config'
    }

    nrc {
        includeConfig 'conf/nrc.config'
    }
}

def check_max(obj, val_type) {
    if (val_type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "ERROR: invalid max_memory: ${params.max_memory}"
            System.exit(1)
        }
    } else if (val_type == 'cpus') {
        try {
            return Math.min(obj, params.max_cpus as int)
        } catch (all) {
            println "ERROR: invalid max_cpus: ${params.max_cpus}"
            System.exit(1)
        }
    } else if (val_type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "ERROR: invalid max_time: ${params.max_time}"
            System.exit(1)
        }
    }
}
