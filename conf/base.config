/*
 * Base config for DADA2-NF
 * Environment-specific settings will be added in profile configs.
 */

params {

    // -------------------------------------------------------------------------
    // Generic options - Nextflow-related
    // -------------------------------------------------------------------------
    help                    = false
    schema_ignore_params    = 'genomes,igenomes_base'
    enable_conda            = false
    singularity_pull_docker_container = false
    outdir                  = "${projectDir}/results"
    publish_dir_mode        = 'copy'
    max_cpus                = 16
    max_memory              = 128.GB
    max_time                = 240.h
    monochrome_logs         = false

    // -------------------------------------------------------------------------
    // Core pipeline
    // -------------------------------------------------------------------------
    workflow_mode = 'short_read'  // 'short_read' | 'long_read' | 'sanger' | 'classification'
    input_reads = null
    marker_gene = 'ITS' // '16S' | 'ITS'
    guide_tree  = true  // true = taxonomy-based guide tree (ITS); false = de novo (16S)
    seqtable    = null  // pre-existing seqtable for classification-only workflow
    run_picrust2 = false
    run_faprotax = false
    run_funguild = false

    // -------------------------------------------------------------------------
    // Primer removal (short read)
    // -------------------------------------------------------------------------
    remove_primers {
        // ITS (Earth Microbiome Project)
        fwd_primer = 'CTTGGTCATTTAGAGGAAGTAA'  // ITS1F
        rev_primer = 'GCTGCGTTCTTCATCGATGC'    // ITS2
        // Standard primer sets as suggested by the Earth Microbiome Project:
        // ITS (ITS1F/ITS2):            fwd='CTTGGTCATTTAGAGGAAGTAA'    rev='GCTGCGTTCTTCATCGATGC'
        // 16S rRNA short (515F/926R):  fwd='GTGYCAGCMGCCGCGGTAA'       rev='CCGYCAATTYMTTTRAGTTT'
        // 16S rRNA long (27F/1468R):   fwd='AGRGTTYGATYMTGGCTCAG'      rev='RGYTACCTTGTTACGACTT'
        // 18S rRNA short (1391F/1510R):fwd='CCAGCASCYGCGGTAATTCC'      rev='ACTTTCGTTCTTGATYRAC'
        min_length = 100
    }

    // -------------------------------------------------------------------------
    // Trim and filter (short read)
    // -------------------------------------------------------------------------
    trim_and_filter {
        truncation_length_fwd = 0    // 0 = no truncation
        truncation_length_rev = 0
        max_n                 = 0
        max_ee_fwd            = 2.0
        max_ee_rev            = 2.0
        trunc_q               = 2
        min_length            = 100
    }

    // -------------------------------------------------------------------------
    // Error learning (short read)
    // -------------------------------------------------------------------------
    learn_errors {
        randomize = 'TRUE'  // 'TRUE' | 'FALSE'
    }

    // -------------------------------------------------------------------------
    // Chimera removal (short read)
    // -------------------------------------------------------------------------
    remove_chimera {
        method = 'consensus'  // 'consensus' | 'pooled' | 'per-sample'
    }

    // -------------------------------------------------------------------------
    // Taxonomic classification: DECIPHER (short read)
    // -------------------------------------------------------------------------
    decipher_classify_taxa {
        strand             = 'both'  // 'top' | 'bottom' | 'both'
        remove_below_level = 2       // 1=domain … 7=species; 2=phylum
        reference_database = null    // set in site profile (e.g. conf/nrc.config) or CLI
    }

    // -------------------------------------------------------------------------
    // Taxonomy aggregation (short read)
    // -------------------------------------------------------------------------
    aggregate {
        na_remove         = 'FALSE' // 'TRUE' | 'FALSE'
    }

    // -------------------------------------------------------------------------
    // MAFFT alignment
    // -------------------------------------------------------------------------
    mafft_alignment {
        algorithm    = 'genafpair'
        max_iterate  = 1000
    }

    // -------------------------------------------------------------------------
    // Primer removal (long read)
    // -------------------------------------------------------------------------
    remove_primers_longread {
        fwd_primer = 'AGRGTTYGATYMTGGCTCAG'  // 27F (16S long)
        rev_primer = 'RGYTACCTTGTTACGACTT'   // 1468R
        // ITS: fwd='CTTGGTCATTTAGAGGAAGTAA' rev='GCTGCGTTCTTCATCGATGC'
    }

    // -------------------------------------------------------------------------
    // Trim and filter (long read)
    // -------------------------------------------------------------------------
    trim_and_filter_longread {
        min_length = 1000
        max_length = 1600
        max_n      = 0
        max_ee     = 2.0
        trunc_q    = 2
        min_q      = 3
        verbose    = 'FALSE'
    }

    // -------------------------------------------------------------------------
    // Dereplication (long read)
    // -------------------------------------------------------------------------
    dereplicate {
        verbose = 'FALSE'
    }

    // -------------------------------------------------------------------------
    // Error learning (long read)
    // -------------------------------------------------------------------------
    learn_errors_longread {
        band_size      = 32
        randomize      = 'TRUE'
        error_function = 'PacBioErrfun'  // 'PacBioErrfun' | 'NanoporeErrfun'
        verbose        = 'FALSE'
    }

    // -------------------------------------------------------------------------
    // Denoising (long read)
    // -------------------------------------------------------------------------
    denoise {
        band_size = 32
        verbose   = 'FALSE'
    }

    // -------------------------------------------------------------------------
    // Chimera removal (long read)
    // -------------------------------------------------------------------------
    remove_chimera_longread {
        method  = 'consensus'
        verbose = 'FALSE'
    }

    // -------------------------------------------------------------------------
    // Taxonomic classification: DADA2 (long read)
    // -------------------------------------------------------------------------
    dada2_classify_taxa {
        orientation        = 'both'   // 'forward' | 'both'
        reference_database = null     // set in site profile (e.g. conf/nrc.config) or CLI
        verbose            = 'FALSE'
    }

    // -------------------------------------------------------------------------
    // Picrust2
    // -------------------------------------------------------------------------
    picrust {
        input_seqs  = null  // path to features FASTA
        input_table = null  // path to feature table TSV
    }

    // -------------------------------------------------------------------------
    // FAPROTAX
    // -------------------------------------------------------------------------
    faprotax {
        collapse_table_script = 'collapse_table.py'
        database_path         = null  // set in site profile (e.g. conf/nrc.config) or CLI
    }

    // -------------------------------------------------------------------------
    // FUNGuild
    // -------------------------------------------------------------------------
    funguild {
        input_table = null  // path to feature table TSV
        local_db    = null  // path to local funguild_db.php copy
    }

    // -------------------------------------------------------------------------
    // Site/runtime overrides — set in site profiles or CLI
    // -------------------------------------------------------------------------
    cluster_options          = ''
    singularity_extra_mounts = ''

    // Container URIs — set in site profiles (e.g. conf/nrc.config)
    container_dada2    = null
    container_mafft    = null
    container_iqtree   = null
    container_fasttree = null
    container_picrust2 = null
    container_faprotax = null
    container_funguild = null
}

