/*
 * Site profile: 16S rRNA short read data
 * Site-specific executor settings and local SIF mappings.
 */

executor {
    name   = "slurm"
    cpus   = 1
    memory = "8 GB"
}

trace {
    overwrite = true
}

timeline {
    overwrite = true
}

report {
    overwrite = true
}

dag {
    overwrite = true
}

params {
    cluster_options = "--account=nrc_eme --export=ALL"

    // -------------------------------------------------------------------------
    // Taxonomic databases (short read — DECIPHER)
    // -------------------------------------------------------------------------
    decipher_classify_taxa {
        reference_database = "$HOST_PROJECT_DIR/assets/test_databases/decipher_16S/DECIPHER_SILVA_SSU_R138.2_NR99_20240918.rds"
        strand             = "both"
        remove_below_level = 2
    }

    // -------------------------------------------------------------------------
    // Functional databases
    // -------------------------------------------------------------------------
    faprotax {
        database_path         = "$HOST_PROJECT_DIR/assets/test_databases/FAPROTAX/FAPROTAX.txt"
    }

    container_dada2    = "file:///$INSTALL_HOME/software/imagefiles/dada2/dada2_mod_v1.1.sif"
    container_mafft    = "file:///$INSTALL_HOME/software/imagefiles/mafft/mafft_v7.525.sif"
    container_fasttree = "file:///$INSTALL_HOME/software/imagefiles/fasttree/fasttree_v2.2.sif"
    container_faprotax = "file:///$INSTALL_HOME/software/imagefiles/faprotax/faprotax_v.1.2.12.sif"
}

process {
    executor       = "slurm"
    clusterOptions = params.cluster_options

    // Default container for DADA2 and related local R/Python steps
    container = params.container_dada2

    // UniFrac tree-building overrides
    withName:MAFFT_ALIGNMENT {
        container = params.container_mafft
        cpus   = 24
        memory = 96.GB
        time   = 24.h
        publishDir = [path: "${params.outdir}/unifrac", mode: 'copy']
        errorStrategy = 'finish'
    }

    withName:FASTTREE_TREE {
        container = params.container_fasttree
        cpus   = 24
        memory = 96.GB
        time   = 24.h
        publishDir = [path: "${params.outdir}/unifrac", mode: 'copy']
        errorStrategy = 'finish'
    }

    withName:FAPROTAX_INTERPRET {
        container = params.container_faprotax
        cpus   = 1
        memory = 8.GB
        time   = 1.h
        publishDir = [path: "${params.outdir}/downstream", mode: 'copy']
        errorStrategy = 'finish'
    }
}
