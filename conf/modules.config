/*
 * Process-level module configuration
 * Short-read resource settings moved here from module files.
 */

process {
    withName: REMOVE_PRIMERS {
        cpus   = 12
        memory = 36.GB
        time   = 1.h
        publishDir = [path: "${params.outdir}/remove_primers", mode: 'copy', pattern: '*.{tsv,png}']
        errorStrategy 'finish'
    }

    withName: TRIM_AND_FILTER {
        cpus   = 12
        memory = 36.GB
        time   = 1.h
        publishDir = [path: "${params.outdir}/trim_and_filter", mode: 'copy', pattern: '*.png']
        errorStrategy 'finish'
    }

    withName: LEARN_ERRORS {
        cpus   = 12
        memory = 36.GB
        time   = 2.h
        publishDir = [path: "${params.outdir}/errors", mode: 'copy']
        errorStrategy 'finish'
    }

    withName: INFER_SAMPLES {
        cpus   = 12
        memory = 36.GB
        time   = 1.h
        publishDir = [path: "${params.outdir}/samples", mode: 'copy']
        errorStrategy 'finish'
    }

    withName: REMOVE_CHIMERA {
        cpus   = 12
        memory = 36.GB
        time   = 1.h
        publishDir = [path: "${params.outdir}/chimera_removal", mode: 'copy']
        errorStrategy 'finish'
    }

    withName: READ_TRACKING {
        cpus   = 1
        memory = 12.GB
        time   = 1.h
        publishDir = [path: "${params.outdir}", mode: 'copy']
        errorStrategy 'finish'
    }

    withName: DECIPHER_CLASSIFY_TAXA {
        cpus   = 12
        memory = 36.GB
        time   = 1.h
        publishDir = [path: "${params.outdir}/classification", mode: 'copy']
        errorStrategy 'finish'
    }

    withName: AGGREGATE_TAXONOMY_FLEX {
        cpus   = 1
        memory = 12.GB
        time   = 1.h
        publishDir = [path: "${params.outdir}/aggregation", mode: 'copy']
        errorStrategy 'finish'
    }

    withName: BUILD_TAX_GUIDE_TREE {
        cpus   = 1
        memory = 12.GB
        time   = 1.h
        publishDir = [path: "${params.outdir}/unifrac", mode: 'copy']
        errorStrategy 'finish'
    }

    withName: MAFFT_ALIGNMENT {
        cpus   = 24
        memory = 96.GB
        time   = 24.h
        publishDir = [path: "${params.outdir}/unifrac", mode: 'copy']
        errorStrategy 'finish'
    }

    withName: IQTREE_TREE {
        cpus   = 24
        memory = 96.GB
        time   = 24.h
        publishDir = [path: "${params.outdir}/unifrac", mode: 'copy']
        errorStrategy 'finish'
    }

    withName: FASTTREE_TREE {
        cpus   = 24
        memory = 96.GB
        time   = 24.h
        publishDir = [path: "${params.outdir}/unifrac", mode: 'copy']
        errorStrategy 'finish'
    }

    withName: REMOVE_PRIMERS_LONGREAD {
        cpus   = 12
        memory = 36.GB
        time   = 1.h
        publishDir = [path: "${params.outdir}/remove_primers", mode: 'copy', pattern: '*.{rds,png,tsv}']
        errorStrategy 'finish'
    }

    withName: TRIM_AND_FILTER_LONGREAD {
        cpus   = 12
        memory = 36.GB
        time   = 1.h
        publishDir = [path: "${params.outdir}/filtered", mode: 'copy', pattern: '*.{rds,png}']
        errorStrategy 'finish'
    }

    withName: DEREPLICATE {
        cpus   = 12
        memory = 36.GB
        time   = 1.h
        publishDir = [path: "${params.outdir}/dereplicated", mode: 'copy']
        errorStrategy 'finish'
    }

    withName: LEARN_ERRORS_LONGREAD {
        cpus   = 12
        memory = 36.GB
        time   = 2.h
        publishDir = [path: "${params.outdir}/errors", mode: 'copy']
        errorStrategy 'finish'
    }

    withName: DENOISE {
        cpus   = 12
        memory = 36.GB
        time   = 1.h
        publishDir = [path: "${params.outdir}/denoise", mode: 'copy']
        errorStrategy 'finish'
    }

    withName: REMOVE_CHIMERA_LONGREAD {
        cpus   = 12
        memory = 36.GB
        time   = 1.h
        publishDir = [path: "${params.outdir}/chimera_removal", mode: 'copy']
        errorStrategy 'finish'
    }

    withName: READ_TRACKING_LONGREAD {
        cpus   = 1
        memory = 12.GB
        time   = 1.h
        publishDir = [path: "${params.outdir}", mode: 'copy']
        errorStrategy 'finish'
    }

    withName: DADA2_CLASSIFY_TAXA {
        cpus   = 12
        memory = 36.GB
        time   = 1.h
        publishDir = [path: "${params.outdir}/classification", mode: 'copy']
        errorStrategy 'finish'
    }

    withName: AGGREGATE_TAXONOMY_LONGREAD {
        cpus   = 1
        memory = 12.GB
        time   = 1.h
        publishDir = [path: "${params.outdir}/aggregation", mode: 'copy']
        errorStrategy 'finish'
    }

    withName: PICRUST2_INTERPRET {
        cpus   = 8
        memory = 48.GB
        time   = 8.h
        publishDir = [path: "${params.outdir}/downstream", mode: 'copy']
        errorStrategy 'finish'
    }

    withName: FAPROTAX_INTERPRET {
        cpus   = 1
        memory = 8.GB
        time   = 1.h
        publishDir = [path: "${params.outdir}/downstream", mode: 'copy']
        errorStrategy 'finish'
    }

    withName: FUNGUILD_INTERPRET {
        cpus   = 1
        memory = 8.GB
        time   = 1.h
        publishDir = [path: "${params.outdir}/downstream", mode: 'copy']
        errorStrategy 'finish'
    }
}
