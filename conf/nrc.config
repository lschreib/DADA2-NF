/*
 * Site profile: NRC HPC
 * Site-specific executor settings and local SIF mappings.
 */

executor {
    name   = 'slurm'
    cpus   = 1
    memory = '8 GB'
}

params {
    cluster_options = '--account=nrc_eme --export=ALL'

    // -------------------------------------------------------------------------
    // Taxonomic databases (short read — DECIPHER)
    // -------------------------------------------------------------------------
    decipher_classify_taxa {
        // ITS (default)
        reference_database = '$DATABASES/dada2/decipher_classifier/unite/DECIPHER_UNITE_v10.0_20241129.rds'
        // 16S alternative:
        // reference_database = '$DATABASES/dada2/decipher_classifier/silva/DECIPHER_SILVA_SSU_R138.2_NR99_20240918.rds'
    }

    // -------------------------------------------------------------------------
    // Taxonomic databases (long read — DADA2)
    // -------------------------------------------------------------------------
    dada2_classify_taxa {
        // 16S GTDB (default)
        reference_database = '$DATABASES/dada2/dada2_classifier/gtdb/ar53_bac120_ssu_reps_r226.dada2_fmt.fna.gz'
        // 16S SILVA alternative:
        // reference_database = '$DATABASES/dada2/dada2_classifier/silva/DADA2_SILVA_138.2_SSURef.fa.gz'
    }

    // -------------------------------------------------------------------------
    // Functional databases
    // -------------------------------------------------------------------------
    faprotax {
        database_path         = '$DATABASES/faprotax/FAPROTAX.txt'
    }

    funguild {
        database_path         = '$DATABASES/funguild/funguild_db.php'
        
    }

    container_dada2    = 'file:///$INSTALL_HOME/software/imagefiles/dada2/dada2_mod_v1.1.sif'
    container_mafft    = 'file:///$INSTALL_HOME/software/imagefiles/mafft/mafft_v7.525.sif'
    container_iqtree   = 'file:///$INSTALL_HOME/software/imagefiles/iqtree/iqtree_v3.11.sif'
    container_fasttree = 'file:///$INSTALL_HOME/software/imagefiles/fasttree/fasttree_v2.2.sif'
    container_picrust2 = 'file:///$INSTALL_HOME/software/imagefiles/picrust2/picrust2_v2.6.2.sif'
    container_faprotax = 'file:///$INSTALL_HOME/software/imagefiles/faprotax/faprotax_v1.2.7.sif'
    container_funguild = 'file:///$INSTALL_HOME/software/imagefiles/funguild/funguild_v1.1.sif'
}

process {
    executor       = 'slurm'
    clusterOptions = params.cluster_options

    // Default container for DADA2 and related local R/Python steps
    container = params.container_dada2

    // UniFrac tree-building overrides
    withName:MAFFT_ALIGNMENT {
        container = params.container_mafft
    }

    withName:IQTREE_TREE {
        container = params.container_iqtree
    }

    withName:FASTTREE_TREE {
        container = params.container_fasttree
    }

    // Future workflow modules
    withName:PICRUST2_INTERPRET {
        container = params.container_picrust2
    }

    withName:FAPROTAX_INTERPRET {
        container = params.container_faprotax
    }

    withName:FUNGUILD_INTERPRET {
        container = params.container_funguild
    }
}
