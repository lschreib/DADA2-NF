/*
 * Test profile for DADA2-NF
 * Keep resource usage small and inputs deterministic.
 */

params {
    input_reads = "${projectDir}/tests/data/reads"
    outdir      = "${projectDir}/results"
    guide_tree  = false
}

process {
    executor = 'local'
    cpus     = 1
    memory   = '1 GB'
    time     = '1h'
}
